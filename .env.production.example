# Required: Neon PostgreSQL connection string
# Get a free database at https://neon.tech
# Format: postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
DATABASE_URL="postgresql://neondb_owner:xxxx@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# Required: Secret for Vercel Cron authentication
# Generate one at: https://generate-secret.vercel.app/32
CRON_SECRET="your-secret-here"
