generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model ScrapeSession {
  id         String        @id @default(cuid())
  startedAt  DateTime      @default(now())
  finishedAt DateTime?
  status     String        @default("running") // running | completed | failed
  error      String?
  rowCount   Int           @default(0)
  records    StockRecord[]

  @@index([startedAt])
  @@index([status])
}

model StockRecord {
  id                 String        @id @default(cuid())
  sessionId          String
  session            ScrapeSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  scrapedAt          DateTime      @default(now())

  // Company
  symbol             String
  companyName        String

  // 52 Weeks Range
  week52High         Float?
  week52Low          Float?

  // Last Trade
  lastTradePrice     Float?
  lastTradeVolume    Int?
  lastTradeChange    Float?
  lastTradePctChange Float?

  // Cumulative
  numberOfTrades     Int?
  cumulativeVolume   Int?

  // Today's
  todayOpen          Float?
  todayHigh          Float?
  todayLow           Float?

  // Best Bid
  bestBidPrice       Float?
  bestBidQuantity    Int?

  // Best Offer
  bestOfferPrice     Float?
  bestOfferQuantity  Int?

  @@index([sessionId])
  @@index([symbol, scrapedAt])
  @@index([scrapedAt])
}

model CompanyProfile {
  id          String   @id @default(cuid())
  symbol      String   @unique
  companyName String
  sector      String?
  details     Json?
  scrapedAt   DateTime @default(now())

  announcements    Announcement[]
  dividends        Dividend[]
  boardMembers     BoardMember[]
  corporateActions CorporateAction[]

  @@index([sector])
}

model Announcement {
  id        String         @id @default(cuid())
  profileId String
  profile   CompanyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     String
  date      String?
  category  String?

  @@index([profileId])
}

model Dividend {
  id               String         @id @default(cuid())
  profileId        String
  profile          CompanyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  announcedDate    String?
  eligibilityDate  String?
  distributionDate String?
  distributionWay  String?
  dividendAmount   String?

  @@index([profileId])
}

model BoardMember {
  id           String         @id @default(cuid())
  profileId    String
  profile      CompanyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  tradingDate  String?
  shareholder  String?
  designation  String?
  sharesHeld   String?
  sharesPrev   String?
  sharesChange String?

  @@index([profileId])
}

model CorporateAction {
  id        String         @id @default(cuid())
  profileId String
  profile   CompanyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title     String
  date      String?
  details   String?

  @@index([profileId])
}

model HistoricalPrice {
  id        String @id @default(cuid())
  symbol    String
  date      String
  open      Float?
  high      Float?
  low       Float?
  close     Float?
  change    Float?
  changePct Float?
  volume    BigInt?
  value     Float?
  trades    Int?

  @@unique([symbol, date])
  @@index([symbol])
  @@index([date])
}
